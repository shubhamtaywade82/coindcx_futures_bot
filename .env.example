# Copy to `.env` and fill in values. Dotenv loads `.env` when present (never commit real secrets).

# --- CoinDCX API (live / doctor / regime context loader) ---
COINDCX_API_KEY=your_api_key_here
COINDCX_API_SECRET=your_api_secret_here

# --- Config path ---
# COINDCX_BOT_CONFIG=/absolute/or/relative/path/to/bot.yml

# --- Live trading: order placement (overrides config runtime.place_orders when set) ---
# PLACE_ORDER=0   # observe-only: feeds + strategy, no orders (synonym: PLACE_ORDERS=0/1; PLACE_ORDER wins if both set)
# PLACE_ORDER=1
# COINDCX_DRY_RUN=1  # optional: force paper (overrides bot.yml); bin/start-dry-run sets this and runs tui only

# --- Runtime profile (overlays scalper defaults when set to `scalper`) ---
# COINDCX_BOT_MODE=scalper
# COINDCX_BOT_MODE=swing

# --- WebSocket (optional; gem default is EIO=3 for CoinDCX + socket.io-client-simple) ---
# COINDCX_SOCKET_BASE_URL=wss://stream.coindcx.com
# COINDCX_SOCKET_EIO=3

# --- Telegram: journal event_log mirror (async; both required to enable) ---
# COINDCX_TELEGRAM_BOT_TOKEN=
# COINDCX_TELEGRAM_CHAT_ID=
# Optional second chat (duplicate selected event types):
# COINDCX_TELEGRAM_OPS_CHAT_ID=
# COINDCX_TELEGRAM_OPS_BOT_TOKEN=   # omit to reuse main bot token
# COINDCX_TELEGRAM_OPS_TYPES=open_failed,smc_setup_invalidated   # comma-separated; empty = no ops duplicates

# --- Ollama: per-brain transport (scoped vars win over YAML, YAML wins over global OLLAMA_*) ---
# Regime narrative (regime.ai). Default to local Ollama via bot.yml; only set to override.
# REGIME_AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
# REGIME_AI_OLLAMA_API_KEY=
# REGIME_AI_MODEL=llama3.2:3b
#
# SMC planner / gatekeeper (smc_setup). Set these when running the planner against Ollama Cloud.
# SMC_SETUP_OLLAMA_BASE_URL=https://ollama.com
# SMC_SETUP_OLLAMA_API_KEY=
# SMC_SETUP_MODEL=gpt-oss:120b-cloud
#
# Local fallback when cloud is unavailable (optional overrides; bot.yml has defaults).
# REGIME_AI_FALLBACK_OLLAMA_BASE_URL=http://127.0.0.1:11434
# REGIME_AI_FALLBACK_MODEL=llama3.2:3b
# SMC_SETUP_FALLBACK_OLLAMA_BASE_URL=http://127.0.0.1:11434
# SMC_SETUP_FALLBACK_MODEL=llama3.2:3b
# SMC_SETUP_FALLBACK_OLLAMA_API_KEY=
#
# When the primary host fails (timeout, 5xx, connection refused), both brains retry once here:
# OLLAMA_FALLBACK_BASE_URL=http://127.0.0.1:11434
# OLLAMA_FALLBACK_MODEL=llama3.2:3b
#
# Global fallback (only used when scoped + YAML are empty). bin/coindcx-agent and bin/ollama-review read these.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=
# OLLAMA_AGENT_MODEL=   # preferred over OLLAMA_MODEL when set
# OLLAMA_API_KEY=

# --- Paper exchange (bin/paper-exchange) ---
# PAPER_EXCHANGE_DB=./data/paper_exchange.sqlite3
# PAPER_EXCHANGE_AUTH_DEBUG=1

# --- App / logging ---
APP_ENV=development
LOG_LEVEL=info

# --- Engine debug ---
# COINDCX_STRATEGY_SIGNALS=1   # log each pair’s strategy signal every tick (noisy)
# COINDCX_WS_TRACE=1           # log every WS tick after gateway parse

# --- TUI ---
# COINDCX_TUI_VERBOSE=1       # keep stderr on the dashboard (noisy)
# COINDCX_TUI_LOG=path        # append stderr here when verbose (default tmp/coindcx_tui.log)
# COINDCX_TUI_LOG_ALL=1       # when verbose, log every api_call 200 and ws_disconnected
# COINDCX_TUI_LOG_MAX_MB=128  # rotate oversized log once at TUI startup
# COINDCX_TUI_LTP_POLL_SECONDS=
# COINDCX_TUI_POLL_ONLY=1    # REST LTP only, no WS tick wake

# --- Ollama agent scripts (bin/coindcx-agent, bin/ollama-review) ---
# OLLAMA_AGENT_ROOT=
