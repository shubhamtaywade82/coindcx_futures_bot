# CoinDCX API Credentials
COINDCX_API_KEY=your_api_key_here
COINDCX_API_SECRET=your_api_secret_here

# WebSocket (optional) — gem default is EIO=3 (CoinDCX + socket.io-client-simple). Override only if needed.
# COINDCX_SOCKET_BASE_URL=wss://stream.coindcx.com
# COINDCX_SOCKET_EIO=3

# Optional: Environment (development, production)
APP_ENV=development
LOG_LEVEL=info

# Engine: log each pair’s strategy signal every tick cycle (mostly :hold). Noisy; use when debugging “no trades”.
# COINDCX_STRATEGY_SIGNALS=1

# TUI: default redirects stderr so WS/gem threads do not paint over the dashboard (stdout).
# COINDCX_TUI_VERBOSE=1 — keep stderr; engine logs to stderr (noisy).
# COINDCX_TUI_LOG=tmp/coindcx_tui.log — append stderr here instead of discarding (implies non-verbose redirect).
# COINDCX_TUI_VERBOSE=1
