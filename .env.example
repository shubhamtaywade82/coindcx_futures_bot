# CoinDCX API Credentials
COINDCX_API_KEY=your_api_key_here
COINDCX_API_SECRET=your_api_secret_here

# WebSocket (optional) — if you see SocketConnectionError, try EIO=3 or EIO=4
# COINDCX_SOCKET_BASE_URL=wss://stream.coindcx.com
# COINDCX_SOCKET_EIO=4

# Optional: Environment (development, production)
APP_ENV=development
LOG_LEVEL=info

# TUI: COINDCX_TUI_VERBOSE=1 — log REST/WS noise to stderr (default WARN+ only, keeps stdout clean for dashboard)
# COINDCX_TUI_VERBOSE=1
