#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift File.expand_path('../lib', __dir__)

# Activate Gemfile deps first (avoids system Rack vs project Rack conflicts when not using `bundle exec`).
require 'bundler/setup'

begin
  require 'dotenv'
  Dotenv.load(File.expand_path('../.env', __dir__), File.expand_path('../.env.local', __dir__))
rescue LoadError
end

require 'coindcx_bot/paper_exchange'
# Rack 3 removed built-in handlers; `rackup` supplies WEBrick.
require 'rackup/handler/webrick'

port = Integer(ENV.fetch('PAPER_EXCHANGE_PORT', 9292))
bind = ENV.fetch('PAPER_EXCHANGE_BIND', '127.0.0.1')

app = CoindcxBot::PaperExchange::Harness.build_app
Rackup::Handler::WEBrick.run(app, Port: port, Host: bind, AccessLog: [])
